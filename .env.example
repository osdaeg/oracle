# ── Gemini ─────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=TuAPIKeyDeGemini

# ── Stable Horde (generación de imágenes) ──────────────────────────────────────
# Registrarse en https://stablehorde.net para mayor prioridad
# Dejar en 0000000000 para usar key anónima (actualmente bloqueada)
STABLE_HORDE_KEY=TuAPIKeyDeStableHorde

# ── Puerto externo ─────────────────────────────────────────────────────────────
ORACLE_EXTERNAL_PORT=7998

# ── Ollama ─────────────────────────────────────────────────────────────────────
# URL del servidor Ollama (puede ser local o remoto)
OLLAMA_URL=http://192.168.88.100:11434
# Modelo a usar (debe estar descargado en Ollama)
OLLAMA_MODEL=gemma3:1b
